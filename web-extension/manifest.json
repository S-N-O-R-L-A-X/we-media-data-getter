{
  "manifest_version": 3,
  "name": "We-Media Data Extractor",
  "version": "1.0.0",
  "description": "自媒体视频数据提取器 - 支持百度贴吧和抖音创作者服务平台",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://tieba.baidu.com/*",
    "https://creator.douyin.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://tieba.baidu.com/home/creative/work*",
        "https://creator.douyin.com/creator-micro/content/manage*"
      ],
      "js": [
        "extractors/base-extractor.js",
        "extractors/tieba-extractor.js",
        "extractors/douyin-extractor.js",
        "extractors/extractor-factory.js",
        "content-script.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "视频数据提取器",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-48.svg",
      "128": "icons/icon-128.svg"
    }
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  }
}